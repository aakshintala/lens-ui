data: {"sequence_number": null, "type": "session.input.consumed", "data": {"item_id": "msg_8b7a2d8a83b942beb22496fd040ed53b", "type": "message", "data": {"role": "user", "content": [{"type": "input_text", "text": "Run this shell command in the terminal: rm -rf /tmp/spike_test_dir && echo done. Ask for my approval before running anything destructive."}], "agent": null}, "created_by": null, "cleared_pending_id": "pending_c67c33adc5c44d138350d8ae6fb4cd16"}}

event: response.output_item.done
data: {"sequence_number": null, "type": "response.output_item.done", "item": {"id": "msg_549979906eae4e6dac7f79cf0a958537", "response_id": "cursor:9be06c0aa963a9f0d38c4746d505460f1fc946cbfd0a05a0c0aa45903ed1b754", "type": "message", "status": "completed", "role": "assistant", "content": [{"type": "output_text", "text": "This command is destructive \u2014 I won't run it until you approve.\n\n**Command:**\n```bash\nrm -rf /tmp/spike_test_dir && echo done\n```\n\n**What it does:**\n1. `rm -rf /tmp/spike_test_dir` \u2014 recursively deletes the directory `/tmp/spike_test_dir` and everything inside it, with no confirmation prompt.\n2. `&& echo done` \u2014 prints `done` only if the removal succeeds.\n\n**Scope:** It only targets `/tmp/spike_test_dir`, not your whole system. Still, anything in that folder is permanently removed.\n\n**Approve?** Reply **yes** to run it, or **no** to skip. If you want a safer check first (e.g. list what's in that directory), say so and I can do that instead."}], "model": "cursor-native-ui"}}

